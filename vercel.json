{
  "name": "hal-tejas-analysis",
  "version": 2,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/server.js" },
    { "source": "/dashboard", "destination": "/public/index.html" },
    { "source": "/(.+\\.css)", "destination": "/public/$1" },
    { "source": "/(.+\\.js)", "destination": "/public/$1" },
    { "source": "/(.+\\.png)", "destination": "/public/$1" },
    { "source": "/(.+\\.jpg)", "destination": "/public/$1" },
    { "source": "/(.+\\.svg)", "destination": "/public/$1" },
    { "source": "/(.*\\.html)", "destination": "/public/$1" },
    { "source": "/", "destination": "/public/login.html" }
  ]
}
