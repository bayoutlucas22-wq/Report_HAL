{
  "name": "hal-tejas-analysis",
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/server.js": {
      "includeFiles": "{data/*.csv,src/data/*.csv}"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/server.js" },
    { "source": "/dashboard", "destination": "/public/dashboard.html" },
    { "source": "/", "destination": "/public/index.html" }
  ]
}
